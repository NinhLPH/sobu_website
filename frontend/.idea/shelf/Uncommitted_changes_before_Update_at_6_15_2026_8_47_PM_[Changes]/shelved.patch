+        if (value == null || value.isNull()) {
+            return "";
+        }
+        if (value.isTextual()) {
+            String text = value.asText();
+            return "null".equals(text) || "undefined".equals(text) ? "" : text;
+        }
+        if (value.isNumber() || value.isBoolean()) {
+            return value.asText();
+        }
+        try {
+            return objectMapper.writeValueAsString(value);
+        } catch (Exception ex) {
+            return value.asText("");
+        }
+    }
