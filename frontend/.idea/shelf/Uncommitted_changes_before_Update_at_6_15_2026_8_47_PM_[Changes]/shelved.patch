+        }
+        attempt.setResponsePayload(updatedPayload);
+        attempt.setCompletedAt(LocalDateTime.now());
+        attempt.setLastMessage(successMessage(attempt.getOperationType(), reconciledResult));
+        nhanhSyncAttemptRepository.save(attempt);
+    }
