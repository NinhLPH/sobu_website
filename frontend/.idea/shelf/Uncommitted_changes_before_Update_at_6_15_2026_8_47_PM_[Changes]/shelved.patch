+                        .mobile(order.getCustomerMobile())
+                        .email(order.getCustomerEmail())
+                        .address(order.getCustomerAddress())
+                        .cityId(order.getCustomerCityId())
+                        .districtId(order.getCustomerDistrictId())
+                        .wardId(order.getCustomerWardId())
