+            Account account = accountRepo.findByEmail(email)
+                    .orElseThrow(() -> new NotFoundException("User not found"));
+            ensureAccountIsActive(account, email);
+
+            if (tokenBlacklistService.isBlacklisted(refreshToken)) {
