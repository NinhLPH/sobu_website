+                        order.getId(),
+                        appOrderId,
+                        item.resolveNhanhOrderId()
+                ),
+                () -> log.warn(
+                        "Could not resolve Nhanh order by lookup: orderId={}, appOrderId={}, orderCode={}",
+                        order.getId(),
+                        appOrderId,
+                        orderCode
+                )
+        );
+
+        return matchedOrder;
