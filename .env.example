# ========================
# Docker Compose
# ========================
COMPOSE_PROJECT_NAME=sobu_website

# ========================
# Images / Containers
# ========================
MYSQL_IMAGE=mysql:8.4
MYSQL_CONTAINER_NAME=sobu-mysql
BACKEND_IMAGE=ghcr.io/ninhlph/sobu-backend:dev
BACKEND_CONTAINER_NAME=sobu-backend

# ========================
# MySQL
# ========================
MYSQL_ROOT_PASSWORD=xxxx
MYSQL_DATABASE=sobu
MYSQL_USER=sobu_user
MYSQL_PASSWORD=xxxx
MYSQL_PORT=3307

# ========================
# Spring
# ========================
SPRING_PROFILES_ACTIVE=docker
BACKEND_PORT=8081
SERVER_PORT=8081
REDIS_HOST=redis
REDIS_PORT=6379
JAVA_TOOL_OPTIONS=-Xms256m -Xmx512m

# ========================
# Web
# ========================
APP_FRONTEND_BASE_URL=http://localhost:3000
SERVER_BASE_URL=http://localhost:8081
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8081,http://localhost:3000
CORS_MAX_AGE=3600
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB
MAX_IN_MEMORY_SIZE=10MB

# ========================
# Datasource
# ========================
DB_URL=jdbc:mysql://mysql:3306/sobu?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=sobu_user
DB_PASSWORD=xxxx
SQL_INIT_MODE=never
DDL_AUTO=update

# ========================
# JWT
# ========================
JWT_SECRET=xxxx
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# ========================
# Security
# ========================
ENCRYPTION_SECRET_KEY=xxxx
API_KEY=xxxx

# ========================
# Storage
# ========================
APP_STORAGE_TYPE=local
APP_STORAGE_LOCAL_DIR=uploads

# ========================
# Google OAuth
# ========================
GOOGLE_CLIENT_ID=
REACT_APP_GOOGLE_CLIENT_ID=

# ========================
# Nhanh Integration
# ========================
NHANH_CLIENT_ID=
NHANH_CLIENT_SECRET=
NHANH_REDIRECT_URI=http://localhost:8081/api/nhanh/oauth/callback
NHANH_BUSINESS_ID=
NHANH_BASE_URL=https://pos.open.nhanh.vn/api
NHANH_SYNC_CRON=0 0 * * * *
NHANH_DEPOT_ID=0
NHANH_ACCOUNTING_ACCOUNT_ID=0
NHANH_LOCATION_PATH=/v3.0/shipping/location
NHANH_LOCATION_VERSION=v1
NHANH_LOCATION_CACHE_TTL_HOURS=24
NHANH_LOCATION_REQUEST_INTERVAL_MS=250
NHANH_LOCATION_RATE_LIMIT_MAX_ATTEMPTS=5
NHANH_LOCATION_RATE_LIMIT_UNLOCK_BUFFER_SECONDS=1
NHANH_LOCATION_RETRY_AFTER_SECONDS=30
NHANH_LOCATION_ROLLING_WINDOW_MS=30000
NHANH_LOCATION_ROLLING_WINDOW_MAX_REQUESTS=120
NHANH_LOCATION_INTER_CHUNK_SLEEP_MS=60000
NHANH_LOCATION_CHUNK_SIZE=5
NHANH_LOCATION_MAX_ATTEMPTS_PER_REQUEST=5
NHANH_LOCATION_EXTENDED_LOCK_THRESHOLD_MS=300000
NHANH_LOCATION_RETRY_BACKOFF_SECONDS=1,2,5

# ========================
# Mail
# ========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
APP_MAIL_FROM_ADDRESS=
MANAGEMENT_HEALTH_MAIL_ENABLED=false

# ========================
# PayOS
# ========================
PAYOS_CLIENT_ID=xxxx
PAYOS_API_KEY=xxxx
PAYOS_CHECKSUM_KEY=xxxx
# Browser redirects only; they do not confirm payment server-side.
PAYOS_RETURN_URL=https://app.example.com/payment/return
PAYOS_CANCEL_URL=https://app.example.com/payment/cancel
# Must be an HTTPS, public, stable backend URL. It is confirmed with PayOS during real-mode startup.
PAYOS_WEBHOOK_URL=https://api.example.com/api/payos/webhooks/callback
PAYOS_GATEWAY_MODE=real
PAYOS_RECONCILIATION_ENABLED=true
PAYOS_RECONCILIATION_INITIAL_DELAY_MS=60000
PAYOS_RECONCILIATION_FIXED_DELAY_MS=60000
PAYOS_RECONCILIATION_STALE_AFTER_SECONDS=120
PAYOS_RECONCILIATION_BATCH_SIZE=50

# ========================
# Redis
# ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# ========================
# Password Reset
# ========================
APP_FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password?token=
RESET_PASSWORD_SECRET_KEY=xxxx
RESET_PASSWORD_TOKEN_EXPIRATION_MS=900000
RESET_PASSWORD_COOLDOWN_MS=60000
