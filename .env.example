# ========================
# Docker Compose
# ========================
COMPOSE_PROJECT_NAME=sobu_website
MYSQL_IMAGE=mysql:8.0
MYSQL_CONTAINER_NAME=sobu-mysql
BACKEND_IMAGE=quanngo205/sobu-backend:1.0.3
BACKEND_CONTAINER_NAME=sobu-backend

# ========================
# MySQL
# ========================
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=sobu
MYSQL_USER=sobu_user
MYSQL_PASSWORD=change_me_user
MYSQL_PORT=3307

# ========================
# Backend Runtime
# ========================
SPRING_PROFILES_ACTIVE=docker
BACKEND_PORT=8081
SERVER_PORT=8081
JAVA_TOOL_OPTIONS=-Xms256m -Xmx512m
SERVER_BASE_URL=http://localhost:8081
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8081
CORS_MAX_AGE=3600

# ========================
# Datasource
# Keep DB_USERNAME/DB_PASSWORD aligned with MYSQL_USER/MYSQL_PASSWORD.
# ========================
DB_URL=jdbc:mysql://mysql:3306/sobu?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=sobu_user
DB_PASSWORD=change_me_user
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/sobu?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
SPRING_DATASOURCE_USERNAME=sobu_user
SPRING_DATASOURCE_PASSWORD=change_me_user

# ========================
# JWT
# ========================
JWT_SECRET=3f9a8c1d7e5b4a2f9c6e8d1b7a3c5f2e9d4b6a1c8e7f5d3b2a9c1e6f8d4b7a2
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# ========================
# Encryption / API
# ========================
ENCRYPTION_SECRET_KEY=9a7c5e3f1b2d4a6c8e0f3b5d7a9c1e2f
API_KEY=docker-api-key-8f3d2c1b7a6e5f4d

# ========================
# Storage
# ========================
APP_STORAGE_TYPE=local
APP_STORAGE_LOCAL_DIR=uploads

# ========================
# Nhanh Integration
# Replace these with real credentials before using sync/OAuth.
# ========================
NHANH_CLIENT_ID=docker-nhanh-client-id
NHANH_CLIENT_SECRET=docker-nhanh-client-secret
NHANH_REDIRECT_URI=http://localhost:8081/api/nhanh/oauth/callback
NHANH_BUSINESS_ID=0
NHANH_BASE_URL=https://pos.open.nhanh.vn/api
NHANH_SYNC_CRON=0 0 * * * *

# ========================
# Mail
# Docker profile is non-prod and uses the no-op sender unless a real sender is configured.
# ========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
